{
  "venvPath": ".",
  "venv": ".conda",
  "typeCheckingMode": "basic",
  "stubPath": "typings",
  "reportAttributeAccessIssue": "none",
  "reportReturnType": "none",
  "include": [
    "api",
    "src",
    "tests"
  ],
  "exclude": [
  ".conda",
    ".git",
    "**/__pycache__"
  ],
  "extraPaths": [
    "."
  ]
}
